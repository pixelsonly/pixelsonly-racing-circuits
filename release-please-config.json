{
  "$schema": "https://raw.githubusercontent.com/googleapis/release-please/main/schemas/config.json",
  "packages": {
    ".": {
      "release-type": "node",
      "package-name": "@pixelsonly/pixelsonly-racing-circuits",
      "changelog-path": "CHANGELOG.md",
      "bump-minor-pre-major": false,
      "bump-patch-for-minor-pre-major": false,
      "draft": false,
      "prerelease": false,
      "changelog-sections": [
        { "type": "feat", "section": "New tracks & additive changes" },
        { "type": "fix", "section": "Data corrections & fixes" },
        { "type": "data", "section": "Data corrections & fixes" },
        { "type": "schema", "section": "Schema changes" },
        { "type": "assets", "section": "Assets" },
        { "type": "docs", "section": "Documentation" },
        { "type": "chore", "section": "Maintenance", "hidden": true }
      ]
    }
  }
}
